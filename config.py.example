def ensure_directories():
    dirs = [
        BASE_DIR / "data",
        BASE_DIR / "logs",
        BASE_DIR / "templates",
        BASE_DIR / "static",
        BASE_DIR / "static" / "css",
        BASE_DIR / "static" / "js",
    ]
    for d in dirs:
        d.mkdir(parents=True, exist_ok=True)


ensure_directories()


def validate_config():
    issues = []
    if EMAIL_CONFIG["sender_email"] == "your_email@163.com":
        issues.append("EMAIL: 发件人邮箱未配置")
    if EMAIL_CONFIG["sender_password"] == "YOUR_SMTP_AUTH_CODE":
        issues.append("EMAIL: SMTP授权码未配置")
    if not issues:
        issues.append("配置检查通过")
    return issues
